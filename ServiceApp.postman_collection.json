{
  "info": {
    "name": "ServiceApp API",
    "description": "Smart Service Marketplace API. Run requests top-to-bottom: the Auth and Create requests auto-save tokens and IDs into collection variables, so later requests just work.\n\nBase URL defaults to http://localhost:5260 (the `http` launch profile). Seeded admin: admin@serviceapp.local / Admin123!.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5260" },
    { "key": "clientToken", "value": "" },
    { "key": "providerToken", "value": "" },
    { "key": "adminToken", "value": "" },
    { "key": "serviceId", "value": "" },
    { "key": "providerId", "value": "" },
    { "key": "bookingId", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register - Client",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "pm.collectionVariables.set('clientToken', json.token);",
                  "pm.test('got token', function () { pm.expect(json.token).to.be.a('string'); });"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/auth/register", "host": ["{{baseUrl}}"], "path": ["api", "auth", "register"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Alice Client\",\n  \"email\": \"alice.client@example.com\",\n  \"password\": \"Passw0rd!\",\n  \"role\": \"Client\"\n}"
            }
          }
        },
        {
          "name": "Register - Provider",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "pm.collectionVariables.set('providerToken', json.token);",
                  "pm.test('got token', function () { pm.expect(json.token).to.be.a('string'); });"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/auth/register", "host": ["{{baseUrl}}"], "path": ["api", "auth", "register"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Bob Provider\",\n  \"email\": \"bob.provider@example.com\",\n  \"password\": \"Passw0rd!\",\n  \"role\": \"Provider\"\n}"
            }
          }
        },
        {
          "name": "Login - Admin (seeded)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "pm.collectionVariables.set('adminToken', json.token);",
                  "pm.test('got token', function () { pm.expect(json.token).to.be.a('string'); });"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/auth/login", "host": ["{{baseUrl}}"], "path": ["api", "auth", "login"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@serviceapp.local\",\n  \"password\": \"Admin123!\"\n}"
            }
          }
        },
        {
          "name": "Login - Client",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "pm.collectionVariables.set('clientToken', json.token);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/auth/login", "host": ["{{baseUrl}}"], "path": ["api", "auth", "login"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"alice.client@example.com\",\n  \"password\": \"Passw0rd!\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Services",
      "item": [
        {
          "name": "Get All Services",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (Array.isArray(json) && json.length) { pm.collectionVariables.set('serviceId', json[0].id); }"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/api/services", "host": ["{{baseUrl}}"], "path": ["api", "services"] }
          }
        },
        {
          "name": "Get Service By Id",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/api/services/{{serviceId}}", "host": ["{{baseUrl}}"], "path": ["api", "services", "{{serviceId}}"] }
          }
        },
        {
          "name": "Create Service (Admin only)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "pm.collectionVariables.set('serviceId', json.id);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "url": { "raw": "{{baseUrl}}/api/services", "host": ["{{baseUrl}}"], "path": ["api", "services"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Painting\",\n  \"category\": \"Home\",\n  \"description\": \"Interior and exterior painting.\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Providers",
      "item": [
        {
          "name": "Search Providers",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/providers?serviceId={{serviceId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "providers"],
              "query": [{ "key": "serviceId", "value": "{{serviceId}}", "description": "Optional filter. Remove to list all." }]
            }
          }
        },
        {
          "name": "Get Provider By Id",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/api/providers/{{providerId}}", "host": ["{{baseUrl}}"], "path": ["api", "providers", "{{providerId}}"] }
          }
        },
        {
          "name": "Create Provider Profile (as Provider user)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "pm.collectionVariables.set('providerId', json.id);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{providerToken}}" }
            ],
            "url": { "raw": "{{baseUrl}}/api/providers", "host": ["{{baseUrl}}"], "path": ["api", "providers"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"serviceId\": \"{{serviceId}}\",\n  \"description\": \"Licensed professional with 5 years experience.\",\n  \"hourlyRate\": 45.00\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Bookings",
      "item": [
        {
          "name": "Create Booking (as Client)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "pm.collectionVariables.set('bookingId', json.id);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{clientToken}}" }
            ],
            "url": { "raw": "{{baseUrl}}/api/bookings", "host": ["{{baseUrl}}"], "path": ["api", "bookings"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"providerId\": \"{{providerId}}\",\n  \"scheduledFor\": \"2026-07-01T10:00:00Z\",\n  \"notes\": \"Please arrive on time.\"\n}"
            }
          }
        },
        {
          "name": "Get Booking By Id",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{clientToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/bookings/{{bookingId}}", "host": ["{{baseUrl}}"], "path": ["api", "bookings", "{{bookingId}}"] }
          }
        },
        {
          "name": "My Bookings (Client)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{clientToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/bookings/mine", "host": ["{{baseUrl}}"], "path": ["api", "bookings", "mine"] }
          }
        },
        {
          "name": "Assigned Bookings (Provider)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{providerToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/bookings/assigned", "host": ["{{baseUrl}}"], "path": ["api", "bookings", "assigned"] }
          }
        },
        {
          "name": "Update Booking Status (Provider confirms)",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{providerToken}}" }
            ],
            "url": { "raw": "{{baseUrl}}/api/bookings/{{bookingId}}/status", "host": ["{{baseUrl}}"], "path": ["api", "bookings", "{{bookingId}}", "status"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"Confirmed\"\n}"
            }
          }
        }
      ]
    }
  ]
}
